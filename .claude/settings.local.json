{
  "permissions": {
    "allow": [
      "PowerShell(Get-WmiObject Win32_LogicalDisk | Select-Object DeviceID, @{N='Free\\(GB\\)';E={[math]::Round\\($_.FreeSpace/1GB,2\\)}}, @{N='Total\\(GB\\)';E={[math]::Round\\($_.Size/1GB,2\\)}})",
      "PowerShell(wmic logicaldisk get DeviceID,FreeSpace,Size)",
      "PowerShell(npm config set cache \"B:\\\\npm-cache\" --global)",
      "PowerShell(npm config get cache)",
      "PowerShell(Get-ChildItem \"b:\\\\portfolio\" -Force | ForEach-Object { Move-Item $_.FullName \"b:\\\\Portfolio\\\\\" -Force }; Get-ChildItem \"b:\\\\Portfolio\")"
    ]
  }
}
